rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSuspended() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('suspended', false) == true;
    }

    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        && !isSuspended();
    }

    // Members: admin read/update only. Registration verification and claiming go
    // through Admin SDK routes now (app/api/register/*); the remaining client write
    // path is the admin "reset membership" action (app/dashboard/admin/users).
    match /members/{memberId} {
      allow read, update: if isAdmin();
      allow create, delete: if false;
    }

    // Users: owner can read their own doc even while suspended (so the app can
    // detect it and self-log-out with a message instead of a permission error).
    // Owner cannot change role, mhspNumber, created_at, or suspended (server/admin only),
    // and cannot write at all while suspended. Admins can read all user docs.
    match /users/{userId} {
      allow read: if request.auth != null
        && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null
        && request.auth.uid == userId
        && !isSuspended()
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['role', 'mhspNumber', 'created_at', 'suspended']);
    }

    // Networks: readable/updatable by any authenticated, non-suspended user; no client-side creates or deletes
    match /networks/{networkId} {
      allow read: if request.auth != null && !isSuspended();
      allow update: if request.auth != null && !isSuspended();
      allow create, delete: if false;
    }

    // Rides: readable by any authenticated, non-suspended user; driver owns create/delete;
    // any authenticated, non-suspended user can update (needed for passengers booking seats)
    match /rides/{rideId} {
      allow read: if request.auth != null && !isSuspended();
      allow create: if request.auth != null
        && !isSuspended()
        && request.resource.data.driverId == request.auth.uid;
      allow update: if request.auth != null && !isSuspended();
      allow delete: if request.auth != null
        && !isSuspended()
        && resource.data.driverId == request.auth.uid;
    }

    // Bookings: readable by passenger, driver, or admin; writable by passenger or driver (unless suspended)
    match /bookings/{bookingId} {
      allow read: if request.auth != null
        && (resource.data.passengerId == request.auth.uid
            || resource.data.driver.id == request.auth.uid
            || isAdmin());
      allow create: if request.auth != null
        && !isSuspended()
        && request.resource.data.passengerId == request.auth.uid;
      allow update: if request.auth != null
        && !isSuspended()
        && (resource.data.passengerId == request.auth.uid
            || resource.data.driver.id == request.auth.uid);
      allow delete: if false;
    }

    // Feedback: anyone can submit; admins can read/update/delete
    match /feedback/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Activity log: any authenticated, non-suspended user may log their own actions;
    // only admins can read the log or modify/delete existing entries
    match /activity_log/{id} {
      allow read: if isAdmin();
      allow create: if request.auth != null
        && !isSuspended()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /config/{id} {
      allow read, write: if isAdmin();
    }

    match /import_sessions/{id} {
      allow read, write: if false;
    }

    // Rate limit counters: Admin SDK only, never touched by client SDKs
    match /rate_limits/{id} {
      allow read, write: if false;
    }

    // Registration verification codes: Admin SDK only, never touched by client SDKs
    match /registration_verifications/{id} {
      allow read, write: if false;
    }
  }
}
